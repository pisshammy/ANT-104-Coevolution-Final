---
const { current } = Astro.props;

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) =>
  `${basePath}${path.replace(/^\/+/, "")}`;

const topics = [
  {
    slug: "home",
    href: "/",
    label: "Overview",
    title: "Coevolution Research",
  },
  {
    slug: "genomic-diet",
    href: "/genomic-diet",
    label: "GENETIC",
    title: "Diet & Nutrition",
  },
  {
    slug: "social-bonds",
    href: "/social-bonds",
    label: "Social",
    title: "Bonds & Cooperation",
  },
  {
    slug: "conclusion",
    href: "/conclusion",
    label: "Conclusion",
    title: "Final Synthesis",
  },
];

const visibleTopics = topics.filter((topic) => topic.slug !== current);
---

<nav class="mt-16 pt-8 border-t border-walnut/10" aria-label="Explore topics">
  <p class="text-sm font-medium text-muted uppercase tracking-wider mb-4">
    Explore Topics
  </p>
  <div class="flex flex-col sm:flex-row sm:justify-center gap-4 sm:gap-6">
    {
      visibleTopics.map((topic) => (
        <a
          href={withBase(topic.href)}
          class="group block p-5 bg-white rounded-xl border border-walnut/5 hover:border-terracotta/30 hover:shadow-sm transition-all duration-200 flex-1 sm:flex-none sm:w-48"
        >
          <span class="text-xs font-medium tracking-wide text-terracotta uppercase">
            {topic.label}
          </span>
          <span class="block mt-1 text-ink font-semibold group-hover:text-terracotta transition-colors">
            {topic.title}
          </span>
        </a>
      ))
    }
  </div>
</nav>
