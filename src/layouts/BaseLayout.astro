---
const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script is:inline>
      function setActiveNav() {
        document.querySelectorAll(".nav-link").forEach(function (link) {
          var linkPath = new URL(link.href).pathname.replace(/\/$/, "") || "/";
          var currentPath = window.location.pathname.replace(/\/$/, "") || "/";
          if (linkPath === currentPath) {
            link.classList.add("text-terracotta");
            link.classList.remove("text-muted");
          } else {
            link.classList.remove("text-terracotta");
            link.classList.add("text-muted");
          }
        });
      }
      document.addEventListener("DOMContentLoaded", setActiveNav);
      document.addEventListener("astro:after-swap", setActiveNav);
    </script>
  </head>
  <body class="bg-paper text-walnut antialiased">
    <nav
      class="bg-paper/80 backdrop-blur-md border-b border-walnut/10 sticky top-0 z-50"
    >
      <div class="relative z-50 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-14">
          <a
            href="/"
            class="flex-shrink-0 text-xs sm:text-sm font-bold tracking-wide uppercase text-terracotta hover:text-walnut transition-colors whitespace-nowrap"
          >
            ANT 104 - INTRO TO BIO ANTHRO
          </a>
          <div class="flex items-center gap-3 sm:gap-6 overflow-x-auto">
            <a
              href="/"
              class="nav-link text-xs tracking-wide text-muted hover:text-terracotta transition-colors whitespace-nowrap"
              >Home</a
            >
            <a
              href="/genomic-diet"
              class="nav-link text-xs tracking-wide text-muted hover:text-terracotta transition-colors whitespace-nowrap"
              >Genomic Diet</a
            >
            <a
              href="/morphology"
              class="nav-link text-xs tracking-wide text-muted hover:text-terracotta transition-colors whitespace-nowrap"
              >Morphology</a
            >
            <a
              href="/social-bonds"
              class="nav-link text-xs tracking-wide text-muted hover:text-terracotta transition-colors whitespace-nowrap"
              >Social Bonds</a
            >
            <a
              href="/conclusion"
              class="nav-link text-xs tracking-wide text-muted hover:text-terracotta transition-colors whitespace-nowrap"
              >Conclusion</a
            >
            <a
              href="/citations"
              class="nav-link text-xs tracking-wide text-muted hover:text-terracotta transition-colors whitespace-nowrap"
              >Citations</a
            >
          </div>
        </div>
      </div>
    </nav>
    <main class="max-w-prose mx-auto px-4 sm:px-6 py-12 leading-relaxed">
      <slot />
    </main>
    <footer
      class="bg-paper/80 backdrop-blur-sm border-t border-walnut/10 mt-20"
    >
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <p class="text-xs text-muted text-center tracking-wide">
          Coevolution Research &mdash; ANT 104
        </p>
      </div>
    </footer>
  </body>
</html>
