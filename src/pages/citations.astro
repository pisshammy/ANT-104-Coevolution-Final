---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Citations - ANT 104">
  <header
    class="relative overflow-hidden bg-gradient-to-br from-paper via-white to-paper py-6 md:py-8"
  >
    <div
      class="pointer-events-none absolute top-0 left-0 w-64 h-64 bg-sage/5 rounded-full -translate-x-1/2 -translate-y-1/2"
    >
    </div>
    <div
      class="pointer-events-none absolute bottom-0 right-0 w-96 h-96 bg-terracotta/5 rounded-full translate-x-1/2 translate-y-1/2"
    >
    </div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 text-center">
      <span
        class="inline-block px-3 py-1 text-xs font-medium tracking-widest uppercase text-terracotta bg-terracotta/10 rounded-full mb-2"
        >References</span
      >
      <h1
        class="whitespace-nowrap text-xl sm:text-2xl md:text-3xl font-bold text-ink mb-2 leading-tight"
      >
        Citations & References
      </h1>
      <p class="text-base text-muted max-w-2xl mx-auto leading-relaxed">
        Source placeholders and image credits for the coevolution research
        pages.
      </p>
    </div>
  </header>
  <section class="max-w-3xl mx-auto px-4 py-12">
    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-ink">Works Cited</h2>
      <div class="space-y-4 text-ink/85 leading-relaxed">
        <p class="pl-8 -indent-8">
          Author Last Name, Author First Name. "Title of Article or Chapter."
          <em>Title of Website, Journal, or Book</em>, Publisher, Day Month
          Year, URL.
        </p>
        <p class="pl-8 -indent-8">
          Author Last Name, Author First Name. <em>Title of Book</em>.
          Publisher, Year.
        </p>
        <p class="pl-8 -indent-8">
          Organization or Institution Name. "Title of Web Page." <em>Website
          Name</em>, Day Month Year, URL. Accessed Day Month Year.
        </p>
      </div>
    </section>

    <section class="mt-12 space-y-4">
      <h2 class="text-2xl font-semibold text-ink">Image Citations</h2>
      <div class="space-y-4 text-ink/85 leading-relaxed">
        <p class="pl-8 -indent-8">
          Coevolutionary process visualization image. URL:
          https://via.placeholder.com/800x400.
        </p>
        <p class="pl-8 -indent-8">
          Genomic diet and nutritional adaptation study image. URL:
          https://via.placeholder.com/800x400.
        </p>
        <p class="pl-8 -indent-8">
          Morphological analysis and anatomical structures image. URL:
          https://via.placeholder.com/800x400.
        </p>
        <p class="pl-8 -indent-8">
          Social bonds and cooperation study image. URL:
          https://via.placeholder.com/800x400.
        </p>
        <p class="pl-8 -indent-8">
          Coevolution of host immunity and pathogen strategies image. URL:
          https://via.placeholder.com/800x400.
        </p>
      </div>
    </section>
  </section>
</BaseLayout>
