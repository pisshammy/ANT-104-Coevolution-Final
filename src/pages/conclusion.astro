---
import BaseLayout from "../layouts/BaseLayout.astro";
import ExploreTopics from "../components/ExploreTopics.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) =>
  `${basePath}${path.replace(/^\/+/, "")}`;
---

<BaseLayout title="Conclusion - ANT 104">
  <header
    class="relative overflow-hidden bg-gradient-to-br from-paper via-white to-paper py-6 md:py-8"
  >
    <div
      class="pointer-events-none absolute top-0 right-0 w-64 h-64 bg-terracotta/5 rounded-full translate-x-1/2 -translate-y-1/2"
    >
    </div>
    <div
      class="pointer-events-none absolute bottom-0 left-0 w-64 h-64 bg-sage/5 rounded-full -translate-x-1/2 translate-y-1/2"
    >
    </div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 text-center">
      <span
        class="inline-block px-3 py-1 text-xs font-medium tracking-widest uppercase text-terracotta bg-terracotta/10 rounded-full mb-2"
        >Conclusion</span
      >
      <h1 class="text-2xl md:text-3xl font-bold text-ink mb-2 leading-tight">
        Conclusion
      </h1>
    </div>
  </header>
  <main class="max-w-3xl mx-auto px-4 py-3">
    <div class="prose-custom space-y-6 text-ink/85 leading-relaxed">
      <h2 class="text-xl font-semibold text-ink mt-8 mb-4">Summary of Findings</h2>
      <p>
        My research aimed to find how human hunting to farming impacted the biological foundations of dogs. While humans were breeding for appearances and luxury since the Victorian era, this research shows human cultural evolution altered dogs' habits and diets for thousands of years.
      </p>

      <h2 class="text-xl font-semibold text-ink mt-8 mb-4">Answering My Core Questions</h2>
      <ul class="list-disc ml-6 space-y-2 text-ink/85">
        <li>
          <strong>When and Why:</strong> Dogs were domesticated during the Paleolithic era societies agriculture era defining change. They originated from an "ancestry distinct from present-day wolves" (Bergström 1).
        </li>
        <li>
          <strong>Social Relationship:</strong> The bond between human and their best companions was emotional and not based on pure function, the Bonn-Oberkassel burial proves this. Human farming did change the relationships however as dogs were no longer hunting companions.
        </li>
        <li>
          <strong>Biological Impacts on Dogs:</strong> The switch of lifestyles forced a genomic mutation and increase of the AMY2B gene, allowing dogs the ability to digest the starch-rich crops human farms grew.
        </li>
      </ul>
    </div>
    <ExploreTopics current="conclusion" />
    <div class="mt-12 pt-8 border-t border-walnut/10 text-center">
      <a
        href={withBase("/citations")}
        class="inline-flex items-center justify-center rounded-md bg-terracotta px-5 py-3 text-sm font-semibold text-white no-underline shadow-sm transition-colors hover:bg-walnut hover:text-white"
      >
        View Citations
      </a>
    </div>
  </main>
</BaseLayout>
